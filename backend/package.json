{
  "name": "viewz-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "ViewZ headless link-opening engine backend",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "worker": "nodemon worker.js",
    "start": "node server.js",
    "start:all": "concurrently \"npm run dev\" \"npm run worker\"",
    "restart:all": "npm run stop:all && npm run start:all",
    "stop:all": "taskkill /F /IM node.exe 2>nul || true"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.3.2",
    "puppeteer": "^22.0.0",
    "socket.io": "^4.7.4",
    "socket.io-client": "^4.7.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.3"
  }
}